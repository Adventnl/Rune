// Generated by the Rune Verilog backend (synthesizable subset only).
// Semantics match the Rune interpreter bit-for-bit.

module alu (
    input [1:0] op,
    input [7:0] a,
    input [7:0] b,
    output [7:0] out
);
    wire [7:0] w0 = (a ^ b);
    wire w1 = (op == 2'd2);
    wire [7:0] w2 = (a & b);
    wire [7:0] w3 = (w1 ? w2 : w0);
    wire w4 = (op == 2'd1);
    wire [7:0] w5 = (a - b);
    wire [7:0] w6 = (w4 ? w5 : w3);
    wire w7 = (op == 2'd0);
    wire [7:0] w8 = (a + b);
    wire [7:0] w9 = (w7 ? w8 : w6);
    assign out = w9;
endmodule
